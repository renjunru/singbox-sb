#!/usr/bin/env python3
"""sb - sing-box mixed 日常管理工具 (macOS / launchd)

命令面与原脚本保持一致；相比原版的主要改进：
- clash_request 只保留一份（去掉重复的 *_quiet 版本）
- 删除死代码 clash_api_ok
- 端口 / Clash API 地址 / secret 从 config.json 读取，常量仅作兜底默认
- start 后轮询等待端口就绪再报状态
- stop 优先 launchctl bootout，仅在仍存活时才兜底 kill
- set_route_main 在匹配为 0 时不写盘、不产生无用备份
- 底层函数抛 SbError，由 main() 统一兜底，便于复用/测试
"""

import base64
import json
import os
import plistlib
import re
import shutil
import socket
import subprocess
import sys
import time
import urllib.parse
import urllib.request
from datetime import datetime
from pathlib import Path

