def curl(url, max_time=30):
    cmd = [
        "curl", "--http1.1", "-L",
        "-x", f"http://{LISTEN_HOST}:{LISTEN_PORT}",
        url, "-o", "/dev/null",
        "-w", "%{http_code}\\n",
        "--max-time", str(max_time),
    ]
    return run(cmd)


def test_main():
    print("YouTube:")
    curl("https://www.youtube.com/", max_time=30)
    print("GitHub:")
    curl("https://github.com/", max_time=30)
    print("Google:")
    curl("https://www.google.com/", max_time=30)


def test_ai():
    print("ChatGPT: 403 也表示已到达 Cloudflare，浏览器可打开为准")
    curl("https://chatgpt.com/", max_time=30)
    print("Claude: 403 也可能是正常 challenge")
    curl("https://claude.ai/", max_time=30)


def test_cn():
    print("Baidu:")
    curl("https://www.baidu.com/", max_time=20)
    print("Doubao:")
    curl("https://www.doubao.com/", max_time=20)


def test_proxy():
    print("代理出口 IP:")
    cmd = [
        "curl", "--http1.1",
        "-x", f"http://{LISTEN_HOST}:{LISTEN_PORT}",
        "https://ip.sb", "--max-time", "20",
    ]
    run(cmd)


def test_all():
    test_main()
    test_ai()
    test_cn()
    test_proxy()


