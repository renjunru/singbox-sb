    current_dir = state.get("current_log_dir") or ""
    print(f"当前运行日志目录：{current_dir if current_dir else '无'}")
    print(f"日志归档根目录：{DIAG_DIR}（按 tun / mixed 分目录；不自动清理，sb log clean 手动清）")


# ---------------------------------------------------------------------------
# 订阅解析：从机场订阅（Clash/Mihomo YAML、Loon/Surge INI、Shadowrocket/通用
# base64、明文 URI 列表）里只提取节点，转成 sing-box 出站 JSON。忽略规则/策略组。
# 支持协议：ss(含 obfs/v2ray-plugin)、vmess、vless(含 reality)、trojan、
# hysteria2、tuic、socks、http；不支持的（ssr/snell 等）跳过并计数。
# ---------------------------------------------------------------------------
SUB_OUT = CONFIG_DIR / "subscription-nodes.json"


def _b64decode_text(s):
    """宽松 base64 解码为文本（兼容 urlsafe、缺省 padding）；失败返回 None。"""
    s = re.sub(r"\s", "", s).replace("-", "+").replace("_", "/")
    s += "=" * (-len(s) % 4)
    try:
        return base64.b64decode(s).decode("utf-8", "replace")
    except Exception:
        return None


def _looks_base64(s):
    s2 = re.sub(r"\s", "", s)
    return bool(s2) and re.fullmatch(r"[A-Za-z0-9+/=_\-]+", s2) is not None


def _split_host_port(s):
    s = s.strip()
    if s.startswith("["):
        host, _, port = s[1:].partition("]:")
    else:
        host, _, port = s.rpartition(":")
    try:
        return host, int(port)
    except (ValueError, TypeError):
        return host, None


def _qs(query):
    return {k: v[0] for k, v in urllib.parse.parse_qs(query).items()}


def _transport(net, path=None, host=None, service=None):
    net = (net or "tcp").lower()
    if net in ("ws", "websocket"):
        tr = {"type": "ws"}
        if path:
            tr["path"] = path
        if host:
            tr["headers"] = {"Host": host}
        return tr
    if net == "grpc":
        return {"type": "grpc", "service_name": service or ""}
    if net in ("h2", "http"):
        tr = {"type": "http"}
        if host:
            tr["host"] = [host]
        if path:
            tr["path"] = path
        return tr
    if net == "httpupgrade":
        tr = {"type": "httpupgrade"}
        if path:
            tr["path"] = path
        if host:
            tr["host"] = host
        return tr
    return None


# ----- URI 协议（Shadowrocket / 通用 base64 / v2rayN）-----
def _u_ss(uri):
    body = uri[5:]
    name = ""
    if "#" in body:
        body, frag = body.split("#", 1)
        name = urllib.parse.unquote(frag)
    plugin = plugin_opts = None
    if "?" in body:
        body, query = body.split("?", 1)
        plug = urllib.parse.unquote(_qs(query).get("plugin", ""))
        if plug:
            parts = plug.split(";")
            plugin, plugin_opts = parts[0], ";".join(parts[1:])
    if "@" in body:
        userinfo, server = body.rsplit("@", 1)
        dec = _b64decode_text(userinfo) or urllib.parse.unquote(userinfo)
        method, _, password = dec.partition(":")
        host, port = _split_host_port(server)
    else:
        dec = _b64decode_text(body) or ""
        creds, _, server = dec.rpartition("@")
        method, _, password = creds.partition(":")
        host, port = _split_host_port(server)
    ob = {"type": "shadowsocks", "tag": name or f"{host}:{port}", "server": host,
          "server_port": port, "method": method, "password": password}
    if plugin in ("obfs-local", "simple-obfs"):
        ob["plugin"] = "obfs-local"
        ob["plugin_opts"] = plugin_opts or ""
    elif plugin == "v2ray-plugin":
        ob["plugin"] = "v2ray-plugin"
        ob["plugin_opts"] = plugin_opts or ""
    return ob


def _u_vmess(uri):
    j = json.loads(_b64decode_text(uri[8:]) or "{}")
    host = j.get("add")
    port = int(j.get("port", 0) or 0)
    ob = {"type": "vmess", "tag": j.get("ps") or f"{host}:{port}", "server": host,
          "server_port": port, "uuid": j.get("id"), "alter_id": int(j.get("aid", 0) or 0),
          "security": j.get("scy") or "auto"}
    if (j.get("tls") or "") in ("tls", "reality", "xtls"):
        t = {"enabled": True}
        sni = j.get("sni") or j.get("host")
        if sni:
            t["server_name"] = sni
        ob["tls"] = t
    tr = _transport(j.get("net"), path=j.get("path"), host=j.get("host"),
                    service=j.get("path") or j.get("host"))
    if tr:
        ob["transport"] = tr
    return ob


def _u_vless(uri):
    u = urllib.parse.urlparse(uri)
    q = _qs(u.query)
    host, port = u.hostname, u.port
    name = urllib.parse.unquote(u.fragment) if u.fragment else f"{host}:{port}"
    ob = {"type": "vless", "tag": name, "server": host, "server_port": port, "uuid": u.username}
    if q.get("flow"):
        ob["flow"] = q["flow"]
    sec = q.get("security", "")
    if sec in ("tls", "reality", "xtls"):
        t = {"enabled": True}
        if q.get("sni"):
            t["server_name"] = q["sni"]
        if sec == "reality":
            r = {"enabled": True}
            if q.get("pbk"):
                r["public_key"] = q["pbk"]
            if q.get("sid"):
                r["short_id"] = q["sid"]
            t["reality"] = r
            t["utls"] = {"enabled": True, "fingerprint": q.get("fp") or "chrome"}
        elif q.get("fp"):
            t["utls"] = {"enabled": True, "fingerprint": q["fp"]}
        ob["tls"] = t
    tr = _transport(q.get("type"), path=q.get("path"), host=q.get("host"), service=q.get("serviceName"))
    if tr:
        ob["transport"] = tr
    return ob


def _u_trojan(uri):
    u = urllib.parse.urlparse(uri)
    q = _qs(u.query)
    host, port = u.hostname, u.port
    name = urllib.parse.unquote(u.fragment) if u.fragment else f"{host}:{port}"
    ob = {"type": "trojan", "tag": name, "server": host, "server_port": port,
          "password": urllib.parse.unquote(u.username or "")}
    t = {"enabled": True}
    sni = q.get("sni") or q.get("peer")
    if sni:
        t["server_name"] = sni
    if q.get("fp"):
        t["utls"] = {"enabled": True, "fingerprint": q["fp"]}
    if q.get("allowInsecure") in ("1", "true"):
        t["insecure"] = True
    ob["tls"] = t
    tr = _transport(q.get("type"), path=q.get("path"), host=q.get("host"), service=q.get("serviceName"))
    if tr:
        ob["transport"] = tr
    return ob


def _u_hy2(uri):
    u = urllib.parse.urlparse(uri)
    q = _qs(u.query)
    host, port = u.hostname, (u.port or 443)
    name = urllib.parse.unquote(u.fragment) if u.fragment else f"{host}:{port}"
    ob = {"type": "hysteria2", "tag": name, "server": host, "server_port": port,
          "password": urllib.parse.unquote(u.username or "")}
    t = {"enabled": True}
    if q.get("sni"):
        t["server_name"] = q["sni"]
    if q.get("insecure") in ("1", "true"):
        t["insecure"] = True
    ob["tls"] = t
    if q.get("obfs"):
        ob["obfs"] = {"type": q["obfs"], "password": q.get("obfs-password", "")}
    return ob


def _u_tuic(uri):
    u = urllib.parse.urlparse(uri)
    q = _qs(u.query)
    host, port = u.hostname, (u.port or 443)
    name = urllib.parse.unquote(u.fragment) if u.fragment else f"{host}:{port}"
    ob = {"type": "tuic", "tag": name, "server": host, "server_port": port,
          "uuid": u.username or "", "password": urllib.parse.unquote(u.password or "")}
    t = {"enabled": True}
    if q.get("sni"):
        t["server_name"] = q["sni"]
    if q.get("alpn"):
        t["alpn"] = q["alpn"].split(",")
    ob["tls"] = t
    if q.get("congestion_control"):
        ob["congestion_control"] = q["congestion_control"]
    return ob


def _u_socks(uri):
    u = urllib.parse.urlparse(uri)
    host, port = u.hostname, u.port
    name = urllib.parse.unquote(u.fragment) if u.fragment else f"{host}:{port}"
    ob = {"type": "socks", "tag": name, "server": host, "server_port": port}
    if u.username:
        ob["username"] = urllib.parse.unquote(u.username)
    if u.password:
        ob["password"] = urllib.parse.unquote(u.password)
    return ob


_URI_PARSERS = {"ss": _u_ss, "vmess": _u_vmess, "vless": _u_vless, "trojan": _u_trojan,
                "hysteria2": _u_hy2, "hy2": _u_hy2, "tuic": _u_tuic,
                "socks": _u_socks, "socks5": _u_socks}


def _parse_uri_list(text):
    nodes, skipped = [], []
    for line in text.splitlines():
        line = line.strip()
        if not line or "://" not in line:
            continue
        scheme = line.split("://", 1)[0].lower()
        fn = _URI_PARSERS.get(scheme)
        ob = None
        if fn:
            try:
                ob = fn(line)
            except Exception:
                ob = None
        if ob and ob.get("server"):
            nodes.append(ob)
        else:
            skipped.append(scheme)
    return nodes, skipped


# ----- 轻量 YAML（仅够解析 Clash proxies；环境无 PyYAML）-----
def _yaml_scalar(s):
    s = s.strip()
    if s == "":
        return None
    if s[0] in "[{":
        return _parse_flow(s)
    if len(s) >= 2 and s[0] == s[-1] and s[0] in "\"'":
        return s[1:-1]
    low = s.lower()
    if low in ("true", "false"):
        return low == "true"
    if low in ("null", "~"):
        return None
    if re.fullmatch(r"-?\d+", s):
        return int(s)
    return s


def _read_flow_scalar(s, i, stop):
    if i < len(s) and s[i] in "\"'":
        q = s[i]
        i += 1
        start = i
        while i < len(s) and s[i] != q:
            i += 1
        return s[start:i], i + 1
    start = i
    while i < len(s) and s[i] not in stop:
        i += 1
    return s[start:i], i


def _parse_flow_at(s, i):
    while i < len(s) and s[i] == " ":
        i += 1
    if i < len(s) and s[i] == "{":
        d = {}
        i += 1
        while i < len(s):
            while i < len(s) and s[i] in " ,":
                i += 1
            if i < len(s) and s[i] == "}":
                return d, i + 1
            key, i = _read_flow_scalar(s, i, ":")
            while i < len(s) and s[i] in " :":
                i += 1
            val, i = _parse_flow_at(s, i)
            d[key.strip()] = val
        return d, i
    if i < len(s) and s[i] == "[":
        arr = []
        i += 1
        while i < len(s):
            while i < len(s) and s[i] in " ,":
                i += 1
            if i < len(s) and s[i] == "]":
                return arr, i + 1
            val, i = _parse_flow_at(s, i)
            arr.append(val)
        return arr, i
    raw, i = _read_flow_scalar(s, i, ",}]")
    return _yaml_scalar(raw), i


def _parse_flow(s):
    val, _ = _parse_flow_at(s.strip(), 0)
    return val


def _tokenize_yaml(text):
    toks = []
    for raw in text.splitlines():
        if not raw.strip() or raw.lstrip().startswith("#"):
            continue
        indent = len(raw) - len(raw.lstrip(" "))
        toks.append((indent, raw.strip()))
    return toks


def _parse_block(toks, i, indent):
    first = toks[i][1]
    if first == "-" or first.startswith("- "):
        seq = []
        while i < len(toks) and toks[i][0] == indent and (toks[i][1] == "-" or toks[i][1].startswith("- ")):
            content = toks[i][1][1:].strip()
            if content == "":
                i += 1
                if i < len(toks) and toks[i][0] > indent:
                    val, i = _parse_block(toks, i, toks[i][0])
                else:
                    val = None
                seq.append(val)
            elif content[0] in "[{":
                seq.append(_parse_flow(content))
                i += 1
            elif ":" in content:
                child = indent + 2
                d = {}
                key, _, rest = content.partition(":")
                d[key.strip().strip("\"'")] = _yaml_scalar(rest.strip())
                i += 1
                while (i < len(toks) and toks[i][0] == child
                       and not (toks[i][1] == "-" or toks[i][1].startswith("- "))):
                    k2, _, r2 = toks[i][1].partition(":")
                    if r2.strip() == "":
                        i += 1
                        if i < len(toks) and toks[i][0] > child:
                            sub, i = _parse_block(toks, i, toks[i][0])
                        else:
                            sub = None
                        d[k2.strip().strip("\"'")] = sub
                    else:
                        d[k2.strip().strip("\"'")] = _yaml_scalar(r2.strip())
                        i += 1
                seq.append(d)
            else:
                seq.append(_yaml_scalar(content))
                i += 1
        return seq, i
    d = {}
    while i < len(toks) and toks[i][0] == indent and not (toks[i][1] == "-" or toks[i][1].startswith("- ")):
        key, _, rest = toks[i][1].partition(":")
        key = key.strip().strip("\"'")
        if rest.strip() == "":
            i += 1
            if i < len(toks) and toks[i][0] > indent:
                val, i = _parse_block(toks, i, toks[i][0])
            else:
                val = None
            d[key] = val
        else:
            d[key] = _yaml_scalar(rest.strip())
            i += 1
    return d, i


def _mini_yaml(text):
    toks = _tokenize_yaml(text)
    if not toks:
        return {}
    obj, _ = _parse_block(toks, 0, toks[0][0])
    return obj


def _clash_to_outbound(p):
    t = (p.get("type") or "").lower()
    name = p.get("name") or f"{p.get('server')}:{p.get('port')}"
    server = p.get("server")
    port = int(p.get("port") or 0)
    base = {"tag": name, "server": server, "server_port": port}
    net = (p.get("network") or "tcp").lower()

    def tls_block(default_sni=None):
        tls = {"enabled": True}
        sni = p.get("sni") or p.get("servername") or p.get("server-name") or default_sni
        if sni:
            tls["server_name"] = sni
        if p.get("skip-cert-verify"):
            tls["insecure"] = True
        alpn = p.get("alpn")
        if alpn:
            tls["alpn"] = alpn if isinstance(alpn, list) else [alpn]
        return tls

    def transport():
        if net == "ws":
            wo = p.get("ws-opts") or {}
            tr = {"type": "ws"}
            path = wo.get("path") or p.get("ws-path")
            if path:
                tr["path"] = path
            headers = wo.get("headers") or {}
            host = headers.get("Host") or headers.get("host")
            if host:
                tr["headers"] = {"Host": host}
            return tr
        if net == "grpc":
            go = p.get("grpc-opts") or {}
            return {"type": "grpc", "service_name": go.get("grpc-service-name", "")}
        if net in ("h2", "http"):
            ho = p.get("h2-opts") or p.get("http-opts") or {}
            tr = {"type": "http"}
            hosts = ho.get("host")
            if hosts:
                tr["host"] = hosts if isinstance(hosts, list) else [hosts]
            path = ho.get("path")
            if path:
                tr["path"] = path if isinstance(path, str) else path[0]
            return tr
        return None

    if t == "ss":
        ob = {"type": "shadowsocks", **base, "method": p.get("cipher"), "password": p.get("password")}
        plugin = p.get("plugin")
        po = p.get("plugin-opts") or {}
        if plugin in ("obfs", "obfs-local", "simple-obfs"):
            opts = f"obfs={po.get('mode', 'http')}"
            if po.get("host"):
                opts += f";obfs-host={po['host']}"
            ob["plugin"] = "obfs-local"
            ob["plugin_opts"] = opts
        elif plugin == "v2ray-plugin":
            opts = "mode=websocket"
            if po.get("host"):
                opts += f";host={po['host']}"
            if po.get("path"):
                opts += f";path={po['path']}"
            if po.get("tls"):
                opts += ";tls"
            ob["plugin"] = "v2ray-plugin"
            ob["plugin_opts"] = opts
        return ob
    if t == "vmess":
        ob = {"type": "vmess", **base, "uuid": p.get("uuid"),
              "alter_id": int(p.get("alterId", 0) or 0), "security": p.get("cipher") or "auto"}
        if p.get("tls"):
            ob["tls"] = tls_block(default_sni=server)
        tr = transport()
        if tr:
            ob["transport"] = tr
        return ob
    if t == "vless":
        ob = {"type": "vless", **base, "uuid": p.get("uuid")}
        if p.get("flow"):
            ob["flow"] = p["flow"]
        if p.get("tls"):
            tls = tls_block(default_sni=server)
            ro = p.get("reality-opts")
            fp = p.get("client-fingerprint")
            if ro:
                tls["reality"] = {"enabled": True, "public_key": ro.get("public-key", ""),
                                  "short_id": ro.get("short-id", "")}
                tls["utls"] = {"enabled": True, "fingerprint": fp or "chrome"}
            elif fp:
                tls["utls"] = {"enabled": True, "fingerprint": fp}
            ob["tls"] = tls
        tr = transport()
        if tr:
            ob["transport"] = tr
        return ob
    if t == "trojan":
        ob = {"type": "trojan", **base, "password": p.get("password"), "tls": tls_block(default_sni=server)}
        tr = transport()
        if tr:
            ob["transport"] = tr
        return ob
    if t in ("hysteria2", "hy2"):
        ob = {"type": "hysteria2", **base, "password": p.get("password") or p.get("auth"),
              "tls": tls_block(default_sni=server)}
        if p.get("obfs"):
            ob["obfs"] = {"type": p["obfs"], "password": p.get("obfs-password", "")}
        return ob
    if t == "tuic":
        ob = {"type": "tuic", **base, "uuid": p.get("uuid"), "password": p.get("password"),
              "tls": tls_block(default_sni=server)}
        if p.get("congestion-controller"):
            ob["congestion_control"] = p["congestion-controller"]
        return ob
    if t in ("socks5", "socks"):
        ob = {"type": "socks", **base}
        if p.get("username"):
            ob["username"] = p["username"]
        if p.get("password"):
            ob["password"] = p["password"]
        return ob
    if t in ("http", "https"):
        ob = {"type": "http", **base}
        if p.get("username"):
            ob["username"] = p["username"]
        if p.get("password"):
            ob["password"] = p["password"]
        return ob
    return None


def _parse_clash(text):
    obj = _mini_yaml(text)
    proxies = obj.get("proxies") if isinstance(obj, dict) else None
    nodes, skipped = [], []
    for p in proxies or []:
        if not isinstance(p, dict):
            continue
        try:
            ob = _clash_to_outbound(p)
        except Exception:
            ob = None
        if ob and ob.get("server"):
            nodes.append(ob)
        else:
            skipped.append(p.get("type") or "?")
    return nodes, skipped


# ----- Loon / Surge INI -----
def _split_csv(s):
    out, cur, q = [], "", None
    for ch in s:
        if q:
            cur += ch
            if ch == q:
                q = None
        elif ch in "\"'":
            q = ch
            cur += ch
        elif ch == ",":
            out.append(cur)
            cur = ""
        else:
            cur += ch
    out.append(cur)
    return out


def _loon_to_outbound(name, typ, parts, kv):
    server = parts[1] if len(parts) > 1 else None
    port = int(parts[2]) if len(parts) > 2 and parts[2].isdigit() else None
    base = {"tag": name, "server": server, "server_port": port}
    if typ in ("shadowsocks", "ss"):
        return {"type": "shadowsocks", **base,
                "method": parts[3] if len(parts) > 3 else kv.get("encrypt-method"),
                "password": (parts[4].strip('"') if len(parts) > 4 else kv.get("password"))}
    if typ == "trojan":
        ob = {"type": "trojan", **base,
              "password": parts[3].strip('"') if len(parts) > 3 else kv.get("password")}
        t = {"enabled": True}
        if kv.get("sni") or kv.get("tls-name"):
            t["server_name"] = kv.get("sni") or kv.get("tls-name")
        if kv.get("skip-cert-verify") == "true":
            t["insecure"] = True
        ob["tls"] = t
        return ob
    if typ == "vmess":
        ob = {"type": "vmess", **base,
              "uuid": kv.get("uuid") or (parts[4].strip('"') if len(parts) > 4 else None),
              "alter_id": int(kv.get("alterid", 0) or 0),
              "security": parts[3] if len(parts) > 3 else "auto"}
        if kv.get("over-tls") == "true" or kv.get("tls") == "true":
            t = {"enabled": True}
            if kv.get("tls-name") or kv.get("sni"):
                t["server_name"] = kv.get("tls-name") or kv.get("sni")
            ob["tls"] = t
        if kv.get("transport") == "ws":
            tr = {"type": "ws"}
            if kv.get("path"):
                tr["path"] = kv["path"]
            if kv.get("host"):
                tr["headers"] = {"Host": kv["host"]}
            ob["transport"] = tr
        return ob
    if typ == "vless":
        ob = {"type": "vless", **base, "uuid": kv.get("uuid")}
        if kv.get("over-tls") == "true" or kv.get("tls") == "true":
            t = {"enabled": True}
            if kv.get("tls-name") or kv.get("sni"):
                t["server_name"] = kv.get("tls-name") or kv.get("sni")
            ob["tls"] = t
        return ob
    return None


def _parse_loon(text):
    nodes, skipped = [], []
    in_proxy = False
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith(("#", ";", "//")):
            continue
        if line.startswith("["):
            in_proxy = line.lower() == "[proxy]"
            continue
        if not in_proxy or "=" not in line:
            continue
        name, _, rhs = line.partition("=")
        name = name.strip()
        parts = [x.strip() for x in _split_csv(rhs)]
        if len(parts) < 3:
            continue
        typ = parts[0].lower()
        kv = {}
        for seg in parts:
            if "=" in seg:
                k, _, v = seg.partition("=")
                kv[k.strip().lower()] = v.strip().strip('"')
        try:
            ob = _loon_to_outbound(name, typ, parts, kv)
        except Exception:
            ob = None
        if ob and ob.get("server"):
            nodes.append(ob)
        else:
            skipped.append(typ)
    return nodes, skipped


def _extract_nodes(content):
    """识别订阅格式并提取节点，返回 (格式名, (nodes, skipped))。"""
    c = content.strip()
    if _looks_base64(c):
        dec = _b64decode_text(c)
        if dec and "://" in dec:
            return "通用/Shadowrocket(base64)", _parse_uri_list(dec)
    if "proxies:" in c:
        return "Clash/Mihomo(YAML)", _parse_clash(c)
    if re.search(r"^\s*\[proxy\]", c, re.I | re.M):
        return "Loon/Surge(INI)", _parse_loon(c)
    if "://" in c:
        return "明文 URI 列表", _parse_uri_list(c)
    raise SbError("无法识别的订阅格式（既不是 base64/Clash/Loon，也没有 URI）。")


def _fetch_sub(source):
    """订阅来源：本地文件 / http(s) URL / 直接的原始内容。"""
    p = Path(source).expanduser()
    if p.exists():
        return p.read_text(encoding="utf-8", errors="replace")
    if source.startswith(("http://", "https://")):
        cmd = ["curl", "-fsSL", "--connect-timeout", "15", "--max-time", "45",
               "-A", "clash-verge/v2.0.0", "--retry", "2"]
        if is_port_listening():
            cmd += ["-x", f"http://{LISTEN_HOST}:{LISTEN_PORT}"]
        cmd += [source]
        r = run(cmd, capture=True)
        if r.returncode != 0 or not r.stdout.strip():
            raise SbError(f"订阅下载失败：{source}\n{r.stderr.strip()}")
        return r.stdout
    return source


def _dedupe_tags(nodes):
    """同名 tag 自动加后缀，保证唯一（并入 config 时不会冲突）。"""
    seen = set()
    for n in nodes:
        tag = n["tag"]
        if tag in seen:
            k = 2
            while f"{tag} #{k}" in seen:
                k += 1
            tag = f"{tag} #{k}"
            n["tag"] = tag
        seen.add(tag)
    return nodes


def _print_sub_result(fmt, nodes, skipped):
    print(f"订阅格式：{fmt}")
    line = f"提取节点：{len(nodes)} 个"
    if skipped:
        line += f"；跳过(不支持) {len(skipped)} 个：{', '.join(sorted(set(skipped)))}"
    print(line)
    if nodes:
        dist = {}
        for n in nodes:
            dist[n["type"]] = dist.get(n["type"], 0) + 1
        print("类型分布：" + ", ".join(f"{k}×{v}" for k, v in sorted(dist.items())))
        print()
        for n in nodes:
            extra = []
            if n.get("tls"):
                extra.append("tls")
            if n.get("transport"):
                extra.append(n["transport"]["type"])
            suffix = f"  ({', '.join(extra)})" if extra else ""
            print(f"  [{n['type']:11}] {n['tag']}  →  {n['server']}:{n['server_port']}{suffix}")


def parse_sub(source, outpath=None):
    """一次性解析（不入库），写出 sing-box 出站 JSON。入库管理见 sb sub add。"""
    fmt, (nodes, skipped) = _extract_nodes(_fetch_sub(source))
    _dedupe_tags(nodes)
    _print_sub_result(fmt, nodes, skipped)
    if not nodes:
        raise SbError("没解析出任何节点（订阅可能为空、或被反爬返回了 HTML）。")
    out = Path(outpath).expanduser() if outpath else SUB_OUT
    out.write_text(json.dumps(nodes, ensure_ascii=False, indent=2), encoding="utf-8")
    print()
    print(f"已写出 sing-box 出站 JSON（{len(nodes)} 个）：{out}")
    print("把里面的对象并入 config.json 的 outbounds，再把对应 tag 加进策略组即可。")


# ---------------------------------------------------------------------------
# 订阅管理：命名保存到 ~/.config/sing-box/subs/<名字>.json，可更新/删除/列出
# 每个文件含 {name,url,format,updated_at,count,nodes:[...sing-box 出站...]}
# ---------------------------------------------------------------------------
SUBS_DIR = CONFIG_DIR / "subs"


def _sub_safe_name(name):
    if not name or name in (".", "..") or re.search(r"[/\\]", name) or name.startswith("."):
        raise SbError(f"订阅名不合法：{name!r}（不能含 / \\、不能以 . 开头）")
    return name


def _sub_path(name):
    return SUBS_DIR / f"{_sub_safe_name(name)}.json"


def _list_subs():
    if not SUBS_DIR.exists():
        return []
    out = []
    for p in sorted(SUBS_DIR.glob("*.json")):
        try:
            out.append(json.loads(p.read_text(encoding="utf-8")))
        except Exception:
            out.append({"name": p.stem, "url": "", "format": "(损坏)", "count": 0, "updated_at": ""})
    return out


def _sub_fetch_save(name, source):
    """抓取 source、解析、存到 subs/<name>.json（覆盖）。返回节点数。"""
    fmt, (nodes, skipped) = _extract_nodes(_fetch_sub(source))
    _dedupe_tags(nodes)
    _print_sub_result(fmt, nodes, skipped)
    if not nodes:
        raise SbError("没解析出任何节点（订阅可能为空、或被反爬返回了 HTML），未保存。")
    is_url = source.startswith(("http://", "https://"))
    data = {
        "name": name,
        "url": source if is_url else "",       # 仅 URL 来源可自动更新
        "source": source,
        "format": fmt,
        "updated_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "count": len(nodes),
        "nodes": nodes,
    }
    SUBS_DIR.mkdir(parents=True, exist_ok=True)
    _sub_path(name).write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
    return len(nodes)


def sub_add(name, source):
    name = _sub_safe_name(name)
    if _sub_path(name).exists():
        raise SbError(f"订阅 '{name}' 已存在。更新用 sb sub update {name}，或先 sb sub del {name}。")
    n = _sub_fetch_save(name, source)
    print()
    print(f"已保存订阅 '{name}'（{n} 节点）：{_sub_path(name)}")


def sub_update(name=None):
    if name is None:
        subs = _list_subs()
        updatable = [s for s in subs if s.get("url")]
        if not subs:
            raise SbError("还没有已保存的订阅。")
        if not updatable:
            raise SbError("没有可更新的订阅（都不是 URL 来源）。")
        for s in updatable:
            print(f"== 更新 '{s['name']}' ==")
            try:
                old = s.get("count", 0)
                n = _sub_fetch_save(s["name"], s["url"])
                print(f"'{s['name']}'：{old} -> {n} 节点\n")
            except SbError as e:
                print(f"'{s['name']}' 更新失败：{e}\n", file=sys.stderr)
        return
    name = _sub_safe_name(name)
    p = _sub_path(name)
    if not p.exists():
        raise SbError(f"没有名为 '{name}' 的订阅。sb sub list 查看。")
    data = json.loads(p.read_text(encoding="utf-8"))
    url = data.get("url")
    if not url:
        raise SbError(f"订阅 '{name}' 不是 URL 来源（来自文件/直接内容），无法自动更新；"
                      f"请 sb sub del {name} 后重新 sb sub add。")
    old = data.get("count", 0)
    n = _sub_fetch_save(name, url)
    print()
    print(f"已更新订阅 '{name}'：{old} -> {n} 节点。")


def sub_list():
    subs = _list_subs()
    if not subs:
        print("还没有已保存的订阅。添加：sb sub add <名字> <订阅URL|文件>")
        return
    active = load_state().get("active_sub") or ""
    print(f"已保存 {len(subs)} 个订阅（{SUBS_DIR}）；★ = 当前已应用：")
    print(f"  {'':2}{'名字':16}{'节点':>5}  {'更新时间':19}  {'格式':22} 来源")
    for d in subs:
        src = d.get("url") or d.get("source") or "(文件/内容)"
        if len(src) > 50:
            src = src[:47] + "..."
        mark = "★ " if d.get("name") == active else "  "
        print(f"  {mark}{d.get('name',''):16}{d.get('count',0):>5}  "
              f"{d.get('updated_at',''):19}  {d.get('format',''):22} {src}")


def sub_del(name):
    name = _sub_safe_name(name)
    p = _sub_path(name)
    if not p.exists():
        raise SbError(f"没有名为 '{name}' 的订阅。sb sub list 查看。")
    p.unlink()
    st = load_state()
    if st.get("active_sub") == name:
        st["active_sub"] = ""
        save_state(st)
    print(f"已删除订阅 '{name}'。")


def sub_show(name):
    name = _sub_safe_name(name)
    p = _sub_path(name)
    if not p.exists():
        raise SbError(f"没有名为 '{name}' 的订阅。sb sub list 查看。")
    data = json.loads(p.read_text(encoding="utf-8"))
    nodes = data.get("nodes", [])
    print(f"订阅 '{name}'：{data.get('count', len(nodes))} 节点 | 更新于 {data.get('updated_at','?')} "
          f"| 来源 {data.get('url') or data.get('source') or '(文件/内容)'}")
    print(f"文件：{p}")
    print()
    _print_sub_result(data.get("format", "?"), nodes, [])


# ----- 选用某订阅：把它的节点应用进 config.json（保留顶层组/路由/DNS）-----
_REGION_ORDER = ["hk", "jp", "sg", "tw", "us"]
_REGION_AUTO = {"hk", "jp", "sg", "tw"}            # us 不做自动测速（AI 需 IP 稳定）
_TOP_GROUPS = {"proxy", "ai", "youtube", "google", "github", "telegram"}
_REGION_KEYS = [
    ("tw", ["台湾", "臺灣", "taiwan", "tw"]),       # 台湾常用 🇨🇳 旗，靠关键词归 tw
    ("hk", ["🇭🇰", "香港", "hongkong", "hong kong", "hk"]),
    ("jp", ["🇯🇵", "日本", "japan", "tokyo", "osaka", "jp"]),
    ("sg", ["🇸🇬", "新加坡", "狮城", "singapore", "sg"]),
    ("us", ["🇺🇸", "美国", "美國", "united states", "america", "los angeles", "san jose", "usa", "us"]),
]


def _detect_region(tag):
    t = tag.lower()
    for region, kws in _REGION_KEYS:
        for kw in kws:
            if re.fullmatch(r"[a-z]{2,3}", kw):           # 字母代码：词边界，防误匹配
                if re.search(r"(?<![a-z])" + kw + r"(?![a-z])", t):
                    return region
            elif kw in tag or kw in t:                    # emoji / 中文 / 英文全名：子串
                return region
    return None


def _apply_sub_nodes(cfg, nodes):
    """保留顶层组与 direct/dns，按地区重建区组，用 nodes 替换叶子节点。返回 (buckets, others)。"""
    reserved = _TOP_GROUPS | set(_REGION_ORDER) | {r + "-auto" for r in _REGION_ORDER} | {"direct", "block"}
    seen = set()
    for n in nodes:
        tag = n["tag"]
        if tag in reserved or tag in seen:
            k = 2
            while f"{tag}~{k}" in seen or f"{tag}~{k}" in reserved:
                k += 1
            tag = f"{tag}~{k}"
            n["tag"] = tag
        seen.add(tag)

    buckets = {r: [] for r in _REGION_ORDER}
    others = []
    for n in nodes:
        r = _detect_region(n["tag"])
        (buckets[r] if r in buckets else others).append(n["tag"])

    old = cfg.get("outbounds", [])
    keep_top = [o for o in old if o.get("tag") in _TOP_GROUPS]
    keep_misc = [o for o in old if o.get("type") in ("direct", "block", "dns")]
    old_region_default = {o["tag"]: o.get("default") for o in old
                          if o.get("tag") in _REGION_ORDER and o.get("type") == "selector"}

    region_groups, region_autos = [], []
    for r in _REGION_ORDER:
        tags = buckets[r]
        has_auto = r in _REGION_AUTO and bool(tags)
        members = ([f"{r}-auto"] if has_auto else []) + tags
        if not members:
            members = ["direct"]
        old_def = old_region_default.get(r)
        if old_def in tags:
            default = old_def
        elif has_auto:
            default = f"{r}-auto"
        elif tags:
            default = tags[0]
        else:
            default = "direct"
        sel = {"type": "selector", "tag": r, "outbounds": members, "default": default}
        if r != "us":
            sel["interrupt_exist_connections"] = True
        region_groups.append(sel)
        if has_auto:
            region_autos.append({"type": "urltest", "tag": f"{r}-auto", "outbounds": tags,
                                 "url": "https://www.gstatic.com/generate_204",
                                 "interval": "3m", "tolerance": 50,
                                 "interrupt_exist_connections": True})

    cfg["outbounds"] = keep_top + region_groups + region_autos + list(nodes) + keep_misc
    return buckets, others


def sub_use(name):
    name = _sub_safe_name(name)
    p = _sub_path(name)
    if not p.exists():
        raise SbError(f"没有名为 '{name}' 的订阅。sb sub list 查看。")
    data = json.loads(p.read_text(encoding="utf-8"))
    nodes = json.loads(json.dumps(data.get("nodes") or []))   # 深拷贝，去重时不改原文件
    if not nodes:
        raise SbError(f"订阅 '{name}' 没有节点。")

    cfg = load_config()
    buckets, others = _apply_sub_nodes(cfg, nodes)

    backup = CONFIG.with_name("config.json.bak-before-subuse")
    shutil.copy2(CONFIG, backup)
    CONFIG.write_text(json.dumps(cfg, ensure_ascii=False, indent=2), encoding="utf-8")
    result = run(["sing-box", "check", "-c", str(CONFIG)], capture=True)
    if result.returncode != 0:
        shutil.copy2(backup, CONFIG)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        raise SbError("应用后配置校验失败，已回滚（config.json 未改动）。")

    st = load_state()
    st["active_sub"] = name
    save_state(st)

    print(f"已切换到订阅 '{name}'（{len(nodes)} 个节点）")
    print("各区分布：" + ", ".join(f"{r}×{len(buckets[r])}" for r in _REGION_ORDER))
    if others:
        print(f"未归类 {len(others)} 个（不在区组里，但已作为出站，可在面板/Clash API 单独选）")
    for r in _REGION_ORDER:
        if not buckets[r]:
            print(f"  ⚠️ {r} 区无节点 → 该区已指向 direct（顶层组里走 {r} 的会变直连）")
    print(f"备份：{backup}")
    print("执行 sb restart 生效。")


# ---------------------------------------------------------------------------
# 帮助 / 入口
# ---------------------------------------------------------------------------
def help_text():
    print("""sb - sing-box 日常管理工具

语法：sb <主题> <动作> [参数]   （start/stop/restart/status 等高频命令在顶层）
组名：proxy ai youtube google github telegram | hk jp sg tw us（区组）| main（=4个服务组）

守护（默认 tun 全局透明代理，需 root）：
  sb start [--mixed]       启动；--mixed = mixed 代理+系统代理（不需 root，Node 类需自带 HTTPS_PROXY）
  sb stop                  停止（自动识别 tun/mixed）并清理系统代理
  sb restart               重启（默认 tun）
  sb status                进程/端口/Clash API/tun/系统代理/策略默认值
  sb tun on|off            显式启停 tun 守护（on 同 start，off 同 stop）

切换节点（不重启，秒生效；重启回配置默认）：
  sb use <组> [list|编号|auto|名字]
    list（或省略）= 列出该组节点（编号/★当前/延迟）；编号 = 切 list 第 N 个；
    auto = 切该组 *-auto；名字 = 按名切（兼容）
  sb use                   等于 group now，看各组当前选择
  例：sb use us list   sb use us 2   sb use sg auto   sb use proxy 5   sb use main 5

设默认（写 config.json，重启后生效；用法与 use 对称，不需 daemon）：
  sb set <组> [list|编号|auto|名字]
  例：sb set us list   sb set us 2   sb set proxy 5   sb set main sg

订阅（入库到 ~/.config/sing-box/subs/，只存节点）：
  sb sub list                    列出已保存订阅（★=当前已应用）
  sb sub add <名字> <URL|文件>   拉取并命名保存（同名拒绝）
  sb sub use <名字>              应用进 config.json（重建区组/替换叶子；备份+校验+回滚），之后 sb restart
  sb sub update [名字]           按保存的 URL 刷新；省略名字=全部
  sb sub show <名字>             查看解析出的节点
  sb sub del <名字>              删除
  sb sub parse <URL|文件> [json] 一次性解析(Clash/Loon/Surge/Shadowrocket/base64)只取节点，不入库

策略组：
  sb groups                所有组情况（类型/当前/出口/延迟/默认差异）
  sb group <组>            看单组详情（成员/★当前/延迟；需 daemon 在跑）
  sb group now             各 selector 当前选择

测试：
  sb test [main|ai|cn|proxy]   省略=全测；main=YT/GH/Google ai=ChatGPT/Claude cn=百度/豆包 proxy=出口IP

日志：
  sb log tail [--tun]      看最新日志（--tun 看 tun 日志）
  sb log on|off|status     开关/查看自动保存日志
  sb log clean             清理历史日志归档

其它：
  sb api | ui | conns      Clash API 测试 / 打开面板 / 抓连接快照
  sb rules update          重下本地 .srs 规则集（带回滚；之后 sb restart）
  sb proxy clean           只清理系统代理残留
""")


# 可切换/可设默认的组（含 main 宏）
GROUP_NAMES = set(USE_GROUPS) | {"main"}


def _arg1(rest, usage):
    if len(rest) != 1:
        raise SbError("用法：" + usage)
    return rest[0]


def _switch(args, group_fn, main_fn, verb):
    """use / set 共用：把组当参数，list/编号/auto/名字交给底层。"""
    if not args:
        if verb == "use":
            selectors()
            return
        raise SbError(f"用法：sb set <组> [list|编号|auto|名字]。组：{', '.join(sorted(GROUP_NAMES))}")
    group = args[0]
    arg = args[1] if len(args) > 1 else "list"
    if group == "main":
        main_fn(arg)
    elif group in USE_GROUPS:
        group_fn(USE_GROUPS[group], arg)
    else:
        raise SbError(f"未知组：{group}。可用：{', '.join(sorted(GROUP_NAMES))}")


def do_start(args):
    if "--mixed" in args or "mixed" in args:
        start_mixed()
    else:
        start()


def do_sub(args):
    action = args[0] if args else "list"
    rest = args[1:]
    if action == "list":
        sub_list()
    elif action == "add":
        if len(rest) != 2:
            raise SbError("用法：sb sub add <名字> <订阅URL|文件>")
        sub_add(rest[0], rest[1])
    elif action == "use":
        sub_use(_arg1(rest, "sb sub use <名字>"))
    elif action == "update":
        sub_update(rest[0] if rest else None)
    elif action == "show":
        sub_show(_arg1(rest, "sb sub show <名字>"))
    elif action == "del":
        sub_del(_arg1(rest, "sb sub del <名字>"))
    elif action == "parse":
        if not rest:
            raise SbError("用法：sb sub parse <订阅URL|文件> [输出json]")
        parse_sub(rest[0], rest[1] if len(rest) > 1 else None)
    else:
        raise SbError(f"未知 sub 动作：{action}。可用：list/add/use/update/show/del/parse")


def do_log(args):
    tun = "--tun" in args
    rest = [a for a in args if a != "--tun"]
    action = rest[0] if rest else "tail"
    if action == "tail":
        logs_tun() if tun else logs()
    elif action == "on":
        log_on()
    elif action == "off":
        log_off()
    elif action == "status":
        log_status()
    elif action == "clean":
        clean_logs()
    else:
        raise SbError(f"未知 log 动作：{action}。可用：tail/on/off/status/clean（tail 可加 --tun）")


def do_test(args):
    t = args[0] if args else "all"
    fns = {"all": test_all, "main": test_main, "ai": test_ai,
           "cn": test_cn, "proxy": test_proxy}
    if t not in fns:
        raise SbError(f"未知 test 目标：{t}。可用：(空)/main/ai/cn/proxy")
    fns[t]()


def do_group(args):
    action = args[0] if args else "ls"
    if action in ("ls", "list"):
        groups()
    elif action == "now":
        selectors()
    elif action == "main":
        list_group_nodes(SERVICE_SELECTORS[MAIN_SERVICES[0]], label="main")
    elif action in USE_GROUPS:
        list_group_nodes(USE_GROUPS[action])
    else:
        raise SbError(
            f"未知 group 参数：{action}。\n"
            f"sb groups 看全部 | sb group <组> 看单组详情 | sb group now 看当前选择")


def do_rules(args):
    action = args[0] if args else "update"
    if action == "update":
        update_rules()
    else:
        raise SbError(f"未知 rules 动作：{action}。可用：update")


def do_tun(args):
    action = args[0] if args else None
    if action == "on":
        tun_on()
    elif action == "off":
        tun_off()
    else:
        raise SbError("用法：sb tun on|off")


def do_proxy(args):
    action = args[0] if args else None
    if action == "clean":
        clean_proxy()
    else:
        raise SbError("用法：sb proxy clean")


def main():
    argv = sys.argv[1:]
    if not argv:
        help_text()
        return

    cmd, args = argv[0], argv[1:]

    noarg = {
        "stop": stop, "restart": restart, "status": status,
        "groups": groups,
        "api": api, "ui": ui, "conns": conns,
        "help": help_text, "-h": help_text, "--help": help_text,
    }
    topics = {
        "sub": do_sub, "log": do_log, "test": do_test, "group": do_group,
        "rules": do_rules, "tun": do_tun, "proxy": do_proxy,
        "start": do_start,
    }

    try:
        if cmd == "use":
            _switch(args, use_group, use_main_group, "use")
        elif cmd == "set":
            _switch(args, route_group, route_main_group, "set")
        elif cmd in topics:
            topics[cmd](args)
        elif cmd in noarg:
            noarg[cmd]()
        else:
            print(f"未知命令：{cmd}", file=sys.stderr)
            help_text()
            sys.exit(1)
    except SbError as e:
        print(str(e), file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
