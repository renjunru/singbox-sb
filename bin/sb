class SbError(Exception):
    """用户可见的、预期内的错误；由 main() 统一打印并退出。"""


# ---------------------------------------------------------------------------
# 运行时设置：尽量从 config.json 读取，读不到则用默认
# ---------------------------------------------------------------------------
def _read_runtime_settings():
    host, port = DEFAULT_LISTEN_HOST, DEFAULT_LISTEN_PORT
    chost, cport = DEFAULT_CLASH_HOST, DEFAULT_CLASH_PORT
    secret = ""

    if CONFIG.exists():
        try:
            data = json.loads(CONFIG.read_text(encoding="utf-8"))
        except Exception:
            data = None

        if isinstance(data, dict):
            for ib in data.get("inbounds", []):
                if ib.get("type") in ("mixed", "http", "socks"):
                    host = ib.get("listen", host)
                    port = ib.get("listen_port", port)
                    break

            clash = data.get("experimental", {}).get("clash_api", {})
            ec = clash.get("external_controller", f"{chost}:{cport}")
            ec_host, _, ec_port = ec.partition(":")
            chost = ec_host or chost
            try:
                cport = int(ec_port) if ec_port else cport
            except ValueError:
                pass
            secret = clash.get("secret", "") or ""

    try:
        port = int(port)
    except (TypeError, ValueError):
        port = DEFAULT_LISTEN_PORT

    return host, port, chost, cport, secret


LISTEN_HOST, LISTEN_PORT, CLASH_HOST, CLASH_PORT, CLASH_SECRET = _read_runtime_settings()
CLASH_API = f"http://{CLASH_HOST}:{CLASH_PORT}"


# ---------------------------------------------------------------------------
# 状态文件 / 日志路径
# ---------------------------------------------------------------------------
def load_state():
    default = {"auto_save_logs": False, "current_log_dir": "", "active_sub": "", "dns_backup": {}}
    if not STATE_FILE.exists():
        return dict(default)
    try:
        with STATE_FILE.open("r", encoding="utf-8") as f:
            state = json.load(f)
        for k, v in default.items():
            state.setdefault(k, v)
        return state
    except Exception:
        return dict(default)


def save_state(state):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with STATE_FILE.open("w", encoding="utf-8") as f:
        json.dump(state, f, ensure_ascii=False, indent=2)


def is_auto_log_enabled():
    return bool(load_state().get("auto_save_logs"))


def mode_log_root(mode):
    """某模式的日志归档根目录：diagnostics/tun 或 diagnostics/mixed。"""
    return DIAG_DIR / mode


def _update_latest(base, run_dir):
    """把 base/latest 软链指向最近一次 run 目录（相对链接，便于 tail -f）。"""
    link = base / "latest"
    try:
        if link.is_symlink() or link.exists():
            link.unlink()
        link.symlink_to(run_dir.name)
    except OSError:
        pass


def prepare_log_paths_for_launch(mode):
    """返回 launchd 的 stdout/stderr 路径；tun 与 mixed 统一走这里。

    mode: "tun" / "mixed"，决定归档到哪个子目录。
    auto_save_logs = True  -> 建独立 run 目录 diagnostics/<mode>/<时间戳>/，
                              并更新该模式的 latest 软链（不自动清理，手动 sb log clean）
    auto_save_logs = False -> 写入 /dev/null
    """
    state = load_state()

    if not state.get("auto_save_logs"):
        state["current_log_dir"] = ""
        save_state(state)
        return "/dev/null", "/dev/null"

    base = mode_log_root(mode)
    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    run_dir = base / timestamp
    run_dir.mkdir(parents=True, exist_ok=True)

    state["current_log_dir"] = str(run_dir)
    save_state(state)
    _update_latest(base, run_dir)

    return str(run_dir / "sing-box.log"), str(run_dir / "sing-box.err.log")


def current_log_paths():
    current_dir = load_state().get("current_log_dir") or ""
    if current_dir:
        d = Path(current_dir)
        return d / "sing-box.log", d / "sing-box.err.log"
    return LOG, ERR_LOG


# ---------------------------------------------------------------------------
# 子进程 / 配置文件
# ---------------------------------------------------------------------------
def run(cmd, check=False, capture=False, timeout=None):
    try:
        if capture:
            return subprocess.run(cmd, check=check, text=True, timeout=timeout,
                                  stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        return subprocess.run(cmd, check=check, timeout=timeout)
    except FileNotFoundError:
        raise SbError(f"找不到命令：{cmd[0]}")
    except subprocess.TimeoutExpired:
        # 超时不致命（典型：osascript 卡在 TCC 授权框）；当作失败返回，由调用方兜底
        return subprocess.CompletedProcess(cmd, returncode=124, stdout="", stderr="")


def require_config():
    if not CONFIG.exists():
        raise SbError(f"找不到配置文件：{CONFIG}")


def load_config():
    require_config()
    with CONFIG.open("r", encoding="utf-8") as f:
        return json.load(f)


def save_config(data):
    backup = CONFIG.with_suffix(".json.bak")
    shutil.copy2(CONFIG, backup)
    with CONFIG.open("w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
    print(f"已保存配置；备份：{backup}")


def check_config():
    result = run(["sing-box", "check", "-c", str(CONFIG)], capture=True)
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        raise SbError("配置检查失败，未继续执行。")


def update_rules():
    """按 rules/sources.json 重新下载本地 .srs 规则集。

    带回滚：先全部下到 .tmp，任一失败即中止（旧规则原样保留）；
    全部成功才替换，替换后校验 config；校验不过自动回滚。
    """
    if not RULES_SOURCES.exists():
        raise SbError(f"找不到规则来源清单：{RULES_SOURCES}")
    try:
        sources = json.loads(RULES_SOURCES.read_text(encoding="utf-8"))
    except Exception as e:
        raise SbError(f"解析 {RULES_SOURCES} 失败：{e}")
    if not isinstance(sources, list) or not sources:
        raise SbError("sources.json 为空或格式不对。")

    use_proxy = is_port_listening()
    if use_proxy:
        print(f"经代理下载：http://{LISTEN_HOST}:{LISTEN_PORT}")
    else:
        print("代理端口未监听，改为直连下载（国内可能失败，建议先 sb start）。")

    RULES_DIR.mkdir(parents=True, exist_ok=True)

    # 阶段 1：全部下载到 .tmp，任一失败即中止
    pending = []  # (dest_path, tmp_path)
    for item in sources:
        tag = item.get("tag", "?")
        url = item.get("url")
        fn = item.get("filename")
        if not url or not fn:
            raise SbError(f"sources.json 条目缺 url/filename：{tag}")

        dest = RULES_DIR / fn
        tmp = RULES_DIR / (fn + ".tmp")
        cmd = ["curl", "-fsSL",
               "--connect-timeout", "15", "--max-time", "45",
               "--retry", "3", "--retry-delay", "2", "--retry-all-errors"]
        if use_proxy:
            cmd += ["-x", f"http://{LISTEN_HOST}:{LISTEN_PORT}"]
        cmd += [url, "-o", str(tmp)]

        result = run(cmd, capture=True)
        if result.returncode != 0 or not tmp.exists() or tmp.stat().st_size == 0:
            tmp.unlink(missing_ok=True)
            for _, t in pending:
                t.unlink(missing_ok=True)
            print(result.stderr.strip(), file=sys.stderr)
            raise SbError(f"下载失败：{tag}（{url}）。已中止，旧规则未改动。")

        print(f"  ✓ {tag}  ({tmp.stat().st_size} B)")
        pending.append((dest, tmp))

    # 阶段 2：原子替换（旧文件挪到 .old，便于回滚）
    swapped = []  # (dest, old_or_None)
    for dest, tmp in pending:
        old = None
        if dest.exists():
            old = dest.with_name(dest.name + ".old")
            dest.replace(old)
        tmp.replace(dest)
        swapped.append((dest, old))

    # 阶段 3：校验，失败则回滚
    print("校验配置…")
    try:
        check_config()
    except SbError:
        for dest, old in swapped:
            if old is not None:
                old.replace(dest)
        raise SbError("更新后配置校验失败，已回滚到旧规则。")

    for _, old in swapped:
        if old is not None:
            old.unlink(missing_ok=True)

    print(f"规则已更新（{len(pending)} 个），配置校验通过。")
    print("执行 sb restart 后生效（本地 rule_set 在启动时加载）。")


# ---------------------------------------------------------------------------
# 系统代理 (networksetup)
# ---------------------------------------------------------------------------
def service_exists(service):
    return run(["networksetup", "-getwebproxy", service], capture=True).returncode == 0


def set_proxy_for_service(service):
    if not service_exists(service):
        print(f"跳过不存在的网络服务：{service}")
        return

    commands = [
        ["networksetup", "-setwebproxy", service, LISTEN_HOST, str(LISTEN_PORT)],
        ["networksetup", "-setsecurewebproxy", service, LISTEN_HOST, str(LISTEN_PORT)],
        ["networksetup", "-setsocksfirewallproxy", service, LISTEN_HOST, str(LISTEN_PORT)],
        ["networksetup", "-setwebproxystate", service, "on"],
        ["networksetup", "-setsecurewebproxystate", service, "on"],
        ["networksetup", "-setsocksfirewallproxystate", service, "on"],
    ]
    for cmd in commands:
        run(cmd)
    print(f"已设置系统代理：{service} -> {LISTEN_HOST}:{LISTEN_PORT}")


def clear_proxy_for_service(service):
    if not service_exists(service):
        print(f"跳过不存在的网络服务：{service}")
        return

    commands = [
        ["networksetup", "-setwebproxystate", service, "off"],
        ["networksetup", "-setsecurewebproxystate", service, "off"],
        ["networksetup", "-setsocksfirewallproxystate", service, "off"],
    ]
    for cmd in commands:
        run(cmd)
    print(f"已关闭系统代理：{service}")


def set_all_proxies():
    for service in NETWORK_SERVICES:
        set_proxy_for_service(service)


def clear_all_proxies():
    for service in NETWORK_SERVICES:
        clear_proxy_for_service(service)


def proxy_status(service):
    if not service_exists(service):
        return "不存在"

    items = [
        ("HTTP", ["networksetup", "-getwebproxy", service]),
        ("HTTPS", ["networksetup", "-getsecurewebproxy", service]),
        ("SOCKS", ["networksetup", "-getsocksfirewallproxy", service]),
    ]

    parts = []
    for name, cmd in items:
        result = run(cmd, capture=True)
        enabled, server, port = "No", "", ""
        for line in result.stdout.splitlines():
            if line.startswith("Enabled:"):
                enabled = line.split(":", 1)[1].strip()
            elif line.startswith("Server:"):
                server = line.split(":", 1)[1].strip()
            elif line.startswith("Port:"):
                port = line.split(":", 1)[1].strip()
        parts.append(f"{name}=ON({server}:{port})" if enabled == "Yes" else f"{name}=off")
    return ", ".join(parts)


# ---------------------------------------------------------------------------
# 系统 DNS（tun 模式守护：堵住 DNS 泄漏，保证 fake-ip 生效）
# ---------------------------------------------------------------------------

def get_service_dns(service):
    """该服务当前手动 DNS 列表；走 DHCP（未手动设置）返回 []。"""
    r = run(["networksetup", "-getdnsservers", service], capture=True)
    out = (r.stdout or "").strip()
    if not out or "aren't any" in out or "There aren" in out:
        return []
    servers = []
    for line in out.splitlines():
        line = line.strip()
        if line and all(c.isdigit() or c in ".:" for c in line):  # 只收 IPv4/IPv6
            servers.append(line)
    return servers


def _set_service_dns(service, servers):
    # servers=[] → 用字面量 "Empty" 还原成 DHCP 自动获取
    arg = list(servers) if servers else ["Empty"]
    run(["networksetup", "-setdnsservers", service] + arg)


def flush_dns_cache():
    run(["dscacheutil", "-flushcache"], capture=True)
    run(["sudo", "killall", "-HUP", "mDNSResponder"], capture=True)  # 需 sudo；失败无妨


def set_tun_dns():
    """tun 启动后调用：备份各网络服务原始 DNS，再改成 TUN_GUARD_DNS。"""
    state = load_state()
    backup = state.get("dns_backup") or {}
    changed = []
    for service in NETWORK_SERVICES:
        if not service_exists(service):
            continue
        cur = get_service_dns(service)
        if cur == TUN_GUARD_DNS:
            continue  # 已是守护值；保留既有备份，不覆盖
        backup[service] = cur  # [] 表示原本走 DHCP
        _set_service_dns(service, TUN_GUARD_DNS)
        changed.append(service)
    if changed:
        state["dns_backup"] = backup
        save_state(state)
        flush_dns_cache()
        print("已将系统 DNS 指向 " + "、".join(TUN_GUARD_DNS) +
              "（" + "、".join(changed) + "），堵住 DNS 泄漏以保证 fake-ip 生效。")


def restore_tun_dns():
    """tun 停止后调用：把各网络服务 DNS 恢复为启动前的原始设置。"""
    state = load_state()
    backup = state.get("dns_backup")
    if not backup:
        return
    for service, servers in backup.items():
        if service_exists(service):
            _set_service_dns(service, servers)
    state["dns_backup"] = {}
    save_state(state)
    flush_dns_cache()
    print("系统 DNS 已恢复为 tun 启动前的设置。")


# ---------------------------------------------------------------------------
# launchd / 进程
# ---------------------------------------------------------------------------
def write_plist():
    sing_box = shutil.which("sing-box")
    if not sing_box:
        raise SbError("找不到 sing-box，请确认已 brew install sing-box。")

    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    PLIST.parent.mkdir(parents=True, exist_ok=True)

    stdout_path, stderr_path = prepare_log_paths_for_launch("mixed")

    plist = {
        "Label": LABEL,
        "ProgramArguments": [sing_box, "run", "-c", str(CONFIG)],
        "RunAtLoad": False,
        "KeepAlive": False,
        "StandardOutPath": stdout_path,
        "StandardErrorPath": stderr_path,
        "WorkingDirectory": str(CONFIG_DIR),
        "EnvironmentVariables": {
            "PATH": os.environ.get(
                "PATH", "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
            )
        },
    }

    with PLIST.open("wb") as f:
        plistlib.dump(plist, f)
    print(f"已写入 LaunchAgent：{PLIST}")


def launchctl_domain():
    return f"gui/{os.getuid()}"


def launchctl_bootout_quiet():
    run(["launchctl", "bootout", launchctl_domain(), str(PLIST)], capture=True)


def launchctl_loaded():
    """launchd 里该任务是否仍处于已加载状态。"""
    return run(
        ["launchctl", "print", f"{launchctl_domain()}/{LABEL}"], capture=True
    ).returncode == 0


def wait_unloaded(timeout=5.0, interval=0.1):
    """等待上一实例彻底卸载、端口释放。

    bootout 是异步的；若紧接着就 bootstrap，旧任务可能还没退干净，
    bootstrap 会返回 5 失败（且被静默吞掉）→ 服务始终没被加载 → sing-box
    没真正启动。restart 正是 stop()+start() 连发，最容易踩到这个竞态。
    """
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not launchctl_loaded() and not is_port_listening():
            return True
        time.sleep(interval)
    return False


def launchctl_bootstrap():
    result = run(["launchctl", "bootstrap", launchctl_domain(), str(PLIST)], capture=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        if "Service is already loaded" not in stderr and "Bootstrap failed: 5" not in stderr:
            print(result.stdout, end="")
            print(result.stderr, end="", file=sys.stderr)
            raise SbError("launchctl bootstrap 失败。")


def launchctl_kickstart():
    result = run(["launchctl", "kickstart", "-k", f"{launchctl_domain()}/{LABEL}"], capture=True)
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        raise SbError("launchctl kickstart 失败。")


def is_port_listening(host=None, port=None):
    host = host or LISTEN_HOST
    port = port or LISTEN_PORT
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(0.5)
        return s.connect_ex((host, port)) == 0


def wait_port(timeout=3.0, interval=0.1):
    deadline = time.time() + timeout
    while time.time() < deadline:
        if is_port_listening():
            return True
        time.sleep(interval)
    return False


def _singbox_proc_lines():
    """真正的 sing-box 进程行（"PID 完整命令行"）。

    pgrep -afil 按整条命令行匹配，命令行里恰好含 "sing-box" 的无关进程
    （例如本脚本自身：配置目录路径就是 .../sing-box）会被误判为 sing-box
    在运行。这里再按"可执行文件名是否为 sing-box"过滤掉它们。
    """
    out = run(["pgrep", "-afil", "sing-box"], capture=True).stdout
    lines = []
    for line in out.splitlines():
        parts = line.split(maxsplit=1)
        if len(parts) == 2 and os.path.basename(parts[1].split(maxsplit=1)[0]) == "sing-box":
            lines.append(line)
    return lines


def pgrep_singbox():
    return "\n".join(_singbox_proc_lines())


def _singbox_proc_has(substr):
    """是否存在命令行里包含 substr 的 sing-box 进程（用于区分代理模式 / tun 模式）。"""
    return any(substr in line for line in _singbox_proc_lines())


def tun_running():
    return _singbox_proc_has(str(TUN_CONFIG))


def proxy_running():
    return _singbox_proc_has(str(CONFIG))


# ---------------------------------------------------------------------------
# Clash API
# ---------------------------------------------------------------------------
# Clash API 是本地接口；必须绕开系统/环境代理。
# 否则 sb start 设置系统代理(127.0.0.1:7890)后，urllib 会把对 9090 的请求
# 也塞进 7890，被 sing-box 掐断 → RemoteDisconnected。
_NO_PROXY_OPENER = urllib.request.build_opener(urllib.request.ProxyHandler({}))


def clash_request(method, path, body=None, timeout=5):
    """底层请求；失败时抛原始异常。"""
    url = f"{CLASH_API}{path}"
    headers, data = {}, None
    if body is not None:
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"
    if CLASH_SECRET:
        headers["Authorization"] = f"Bearer {CLASH_SECRET}"

    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    with _NO_PROXY_OPENER.open(req, timeout=timeout) as resp:
        raw = resp.read()
        return json.loads(raw.decode("utf-8")) if raw else None


def clash_api_available(timeout=2):
    try:
        data = clash_request("GET", "/proxies", timeout=timeout)
        return isinstance(data, dict) and "proxies" in data
    except Exception:
        return False


def get_proxies():
    try:
        data = clash_request("GET", "/proxies")
    except Exception as e:
        raise SbError(
            f"Clash API 请求失败：{CLASH_API}/proxies\n错误：{e}\n"
            f"请确认 sing-box 已启动，且 config.json 已开启 "
            f"experimental.clash_api {CLASH_HOST}:{CLASH_PORT}。"
        )
    return data.get("proxies", {}) if isinstance(data, dict) else {}


def clash_select(selector, target):
    encoded = urllib.parse.quote(selector, safe="")
    try:
        clash_request("PUT", f"/proxies/{encoded}", {"name": target})
    except Exception as e:
        raise SbError(f"即时切换失败：{selector} -> {target}\n错误：{e}")
    print(f"已即时切换：{selector} -> {target}")


# ---------------------------------------------------------------------------
# 生命周期
# ---------------------------------------------------------------------------
def kill_other_proxies():
    """关掉系统里其它科学上网 GUI，给 sing-box 让出系统代理 / TUN。

    按白名单 OTHER_PROXY_APPS 逐个处理：先 osascript 优雅退出（让网络扩展
    干净注销），再用 pkill 按 .app 路径兜底强杀（含 .app 内的 TUN 扩展进程）。
    只动用户态进程；root helper 不碰（pkill 杀不动 root，会被静默忽略，不弹
    sudo）。检测用更严格的 /Contents/MacOS/ 匹配，避免把空闲的 root helper
    误算成"GUI 在跑"。返回实际处理的应用名单。

    注：首次 osascript 退出某个 app 时，macOS 可能弹一次「自动化」授权框；
    即便拒绝，后面的 pkill 兜底仍会生效。
    """
    running = [
        app for app in OTHER_PROXY_APPS
        if run(["pgrep", "-f", f"/{app}.app/Contents/MacOS/"], capture=True).stdout.strip()
    ]
    if not running:
        return []

    for app in running:
        run(["osascript", "-e", f'quit app "{app}"'], capture=True, timeout=5)
    # 轮询等它们优雅退出，最多 1.5s；退得快就立刻继续，不再死等满 1 秒
    deadline = time.time() + 1.5
    while time.time() < deadline:
        still = [
            app for app in running
            if run(["pgrep", "-f", f"/{app}.app/Contents/MacOS/"], capture=True).stdout.strip()
        ]
        if not still:
            break
        time.sleep(0.1)
    for app in running:
        run(["pkill", "-f", f"/{app}.app/"], capture=True)
    return running


def start():
    """默认以 tun（全局透明代理，root 守护）方式启动。

    想用 mixed 代理模式（不需 root）请用 sb start --mixed。
    """
    start_tun()


def restart():
    stop()
    start()


def start_mixed():
    if tun_running():
        raise SbError("tun 模式（root 守护）正在运行，会抢占端口。请先 sb stop（或 sb tun off）再启动 mixed 模式。")
    check_config()
    killed = kill_other_proxies()
    if killed:
        print("已关闭其它科学上网工具：" + "、".join(killed))
    write_plist()
    launchctl_bootout_quiet()
    wait_unloaded()  # 等旧实例退干净再 bootstrap，避免 restart 的 launchd 竞态
    launchctl_bootstrap()
    launchctl_kickstart()

    if not wait_port():
        print("警告：端口暂未就绪，sing-box 可能仍在启动或启动失败。", file=sys.stderr)

    set_all_proxies()
    print("sing-box mixed 已后台启动。")

    if is_auto_log_enabled():
        out_log, err_log = current_log_paths()
        print("自动保存日志：已开启")
        print(f"stdout：{out_log}")
        print(f"stderr：{err_log}")
    else:
        print("自动保存日志：已关闭；后台日志写入 /dev/null")
    status()


def stop():
    """停掉当前在跑的模式，自动识别 tun / mixed。"""
    if tun_running():
        stop_tun()
    elif proxy_running() or is_port_listening() or pgrep_singbox():
        stop_mixed()
    else:
        clear_all_proxies()
        print("sing-box 未在运行；系统代理已清理。")


def stop_mixed():
    launchctl_bootout_quiet()
    # bootout 后通常已退出；仅在仍存活时兜底（此处只可能是用户态代理进程）
    if is_port_listening() or pgrep_singbox():
        run(["pkill", "-x", "sing-box"], capture=True)
    clear_all_proxies()
    print("sing-box（mixed）已停止，系统代理已清理。")


# ---------------------------------------------------------------------------
# tun 模式（root 后台守护：/Library/LaunchDaemons + system 域）
# ---------------------------------------------------------------------------
def sudo_prime():
    """确保后续 sudo 调用不会在 capture 时静默卡住。

    若已为 tun 守护配置免密 sudo（见 /etc/sudoers.d/sb-singbox-tun），直接返回，
    全程不弹密码；否则交互式 sudo -v 预热一次凭据（之后的 capture 调用不再卡）。
    """
    probe = run(
        ["sudo", "-n", "-l", "/bin/launchctl", "bootout", f"system/{DAEMON_LABEL}"],
        capture=True,
    )
    if probe.returncode == 0:
        return
    if run(["sudo", "-v"]).returncode != 0:
        raise SbError("需要管理员权限（sudo）来管理 tun 模式的 root 后台守护。")


def build_tun_config():
    """用 config.json + tun-inbound.json 合成 config.tun.json，并校验。"""
    require_config()
    if not TUN_INBOUND.exists():
        raise SbError(
            f"找不到 tun 入站定义：{TUN_INBOUND}\n"
            f"（默认配置不含 tun；该文件是拆分时抽出的 tun 块。）"
        )
    try:
        tun_ib = json.loads(TUN_INBOUND.read_text(encoding="utf-8"))
    except Exception as e:
        raise SbError(f"解析 {TUN_INBOUND} 失败：{e}")

    data = load_config()
    inbounds = [ib for ib in data.get("inbounds", []) if ib.get("type") != "tun"]
    data["inbounds"] = [tun_ib] + inbounds
    TUN_CONFIG.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")

    result = run(["sing-box", "check", "-c", str(TUN_CONFIG)], capture=True)
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        raise SbError("tun 配置检查失败，未继续执行。")


def write_daemon_plist():
    """生成 daemon plist 并以 root:wheel 0644 安装到 /Library/LaunchDaemons。"""
    sing_box = shutil.which("sing-box")
    if not sing_box:
        raise SbError("找不到 sing-box，请确认已 brew install sing-box。")

    stdout_path, stderr_path = prepare_log_paths_for_launch("tun")

    plist = {
        "Label": DAEMON_LABEL,
        "ProgramArguments": [sing_box, "run", "-c", str(TUN_CONFIG)],
        "RunAtLoad": True,
        # tun 是全局接管路由的"基础设施"，崩溃=整机断网，故自动重启
        "KeepAlive": True,
        "StandardOutPath": stdout_path,
        "StandardErrorPath": stderr_path,
        "WorkingDirectory": str(CONFIG_DIR),
        "EnvironmentVariables": {
            "PATH": os.environ.get(
                "PATH", "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
            )
        },
    }

    tmp = CONFIG_DIR / (DAEMON_PLIST.name + ".tmp")
    with tmp.open("wb") as f:
        plistlib.dump(plist, f)

    # launchd 要求 system 域的 plist 属于 root 且非组/他人可写
    result = run(
        ["sudo", "install", "-m", "644", "-o", "root", "-g", "wheel",
         str(tmp), str(DAEMON_PLIST)],
        capture=True,
    )
    tmp.unlink(missing_ok=True)
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        raise SbError(f"安装 LaunchDaemon 失败：{DAEMON_PLIST}")
    print(f"已写入 LaunchDaemon：{DAEMON_PLIST}")


def daemon_bootout_quiet():
    run(["sudo", "launchctl", "bootout", f"system/{DAEMON_LABEL}"], capture=True)


def daemon_bootstrap():
    result = run(["sudo", "launchctl", "bootstrap", "system", str(DAEMON_PLIST)], capture=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        if "already loaded" not in stderr.lower() and "Bootstrap failed: 5" not in stderr:
            print(result.stdout, end="")
            print(result.stderr, end="", file=sys.stderr)
            raise SbError("sudo launchctl bootstrap system 失败。")


def daemon_kickstart():
    result = run(["sudo", "launchctl", "kickstart", "-k", f"system/{DAEMON_LABEL}"], capture=True)
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        raise SbError("sudo launchctl kickstart 失败。")


def start_tun():
    """默认启动方式：tun 全局透明代理（root 守护，开机自启）。

    所有程序（含不读系统代理的 Node 程序，如 Claude Code）都被 auto_route
    全局接管，按 config.json 里的 route.rules 照常分流。
    """
    require_config()
    killed = kill_other_proxies()
    if killed:
        print("已关闭其它科学上网工具：" + "、".join(killed))
    # 先让出 7890 端口：mixed 在跑就先停（用户态，无需 sudo）；否则清掉系统代理
    if proxy_running():
        print("检测到 mixed 代理在运行，先停止它…")
        stop_mixed()
    else:
        clear_all_proxies()  # tun 靠 auto_route 全局接管，不需要系统代理

    sudo_prime()
    build_tun_config()
    write_daemon_plist()
    daemon_bootout_quiet()
    daemon_bootstrap()
    daemon_kickstart()

    if not wait_port():
        print("警告：端口暂未就绪，tun 可能仍在启动或启动失败。可执行 sb log tail --tun 查看。",
              file=sys.stderr)

    set_tun_dns()  # 堵住 DNS 泄漏，保证 fake-ip 生效（详见 TUN_GUARD_DNS 注释）

    print("sing-box tun 模式已启动（root 后台守护，开机自启）。")
    status(quick=True)


def tun_on():
    start_tun()


def stop_tun():
    sudo_prime()
    daemon_bootout_quiet()
    if tun_running():
        run(["sudo", "pkill", "-x", "sing-box"], capture=True)
    restore_tun_dns()  # 还原启动前的系统 DNS
    print("sing-box tun 模式已停止。")


def tun_off():
    stop_tun()


def latest_run_dir(mode):
    """某模式最近一次 run 目录：优先 latest 软链，否则取时间戳最大的子目录。"""
    base = mode_log_root(mode)
    link = base / "latest"
    if link.is_symlink():
        target = link.resolve()
        if target.exists():
            return target
    if base.exists():
        dirs = sorted(d for d in base.iterdir() if d.is_dir() and not d.is_symlink())
        if dirs:
            return dirs[-1]
    return None


def _show_run_logs(run_dir, label):
    """tail -f 某 run 目录里有内容的日志（sing-box 主要写 stderr，优先它）。"""
    if run_dir is None:
        print(f"{label}还不存在（尚未以该模式启动过，或日志保存处于关闭状态）。")
        return
    err_log = run_dir / "sing-box.err.log"
    out_log = run_dir / "sing-box.log"
    existing = [p for p in (err_log, out_log) if p.exists()]
    if not existing:
        print(f"{label}目录暂无日志文件：{run_dir}")
        return
    for log_file in existing:
        if log_file.stat().st_size > 0:
            print(f"正在查看{label}：{log_file}")
            subprocess.run(["tail", "-f", str(log_file)])
            return
    print(f"{label}当前为空，等待新日志：{existing[0]}")
    subprocess.run(["tail", "-f", str(existing[0])])


def logs_tun():
    _show_run_logs(latest_run_dir("tun"), "tun 日志")


def clean_proxy():
    clear_all_proxies()
    print("系统代理残留已清理。")


def _dir_size(p):
    total = 0
    for f in p.rglob("*"):
        try:
            if f.is_file():
                total += f.stat().st_size
        except OSError:
            pass
    return total


def clean_logs():
    """清掉历史日志归档（tun/mixed 各时间戳目录），保留当前正在写的那次。"""
    cur = load_state().get("current_log_dir") or ""
    cur_path = Path(cur).resolve() if cur else None

    removed, freed = 0, 0
    for mode in LOG_MODES:
        base = mode_log_root(mode)
        if not base.exists():
            continue
        for d in list(base.iterdir()):
            if d.is_symlink() or not d.is_dir():
                continue
            if cur_path and d.resolve() == cur_path:
                continue  # 保留当前正在写入的 run 目录
            freed += _dir_size(d)
            shutil.rmtree(d, ignore_errors=True)
            removed += 1
        # latest 软链若已悬空则删掉
        link = base / "latest"
        if link.is_symlink() and not link.resolve().exists():
            link.unlink(missing_ok=True)

    print(f"已清理 {removed} 个历史日志目录，释放约 {_human_bytes(freed)}。")
    if cur_path:
        print(f"保留当前运行日志：{cur_path}")


def status(quick=False):
    print()
    print("== sing-box ==")
    procs = pgrep_singbox()
    if procs:
        print("进程：running")
        print(procs)
    else:
        print("进程：stopped")

    print(f"端口 {LISTEN_PORT}：{'listening' if is_port_listening() else 'not listening'}")
    if quick:
        # 启动刚结束时 Clash API(9090) 往往还没就绪，探测会白等满 2s 超时；
        # 这里跳过它和运行时选择，避免拖慢 restart。完整状态用 `sb status` 查看。
        api_up = False
        print(f"Clash API {CLASH_PORT}：启动中（稍后用 sb status 查看）")
    else:
        api_up = clash_api_available()
        print(f"Clash API {CLASH_PORT}：{'available' if api_up else 'not available'}")

    if tun_running():
        print("tun 模式：running（root 后台守护）")
    elif DAEMON_PLIST.exists():
        print("tun 模式：stopped（daemon 已安装，sb tun on 启动）")
    else:
        print("tun 模式：off（未安装；sb tun on 启用）")

    print()
    print("== 日志记录 ==")
    if is_auto_log_enabled():
        cur = load_state().get("current_log_dir") or ""
        print("自动保存日志：开启（tun / mixed 统一归档）")
        print(f"当前日志目录：{cur if cur else '(下次启动时生成)'}")
        print("查看：sb log tail（当前模式最新） / sb log tail --tun（tun 最新）")
    else:
        print("自动保存日志：关闭（sb log on + sb restart 开启）")

    print()
    print("== 系统代理 ==")
    for service in NETWORK_SERVICES:
        print(f"{service}: {proxy_status(service)}")

    print()
    print("== 配置默认值 ==")
    data = load_config()
    for tag in WANTED_SELECTORS:
        for outbound in data.get("outbounds", []):
            if outbound.get("tag") == tag:
                print(f"{tag}: {outbound.get('default', '(无 default)')}")
                break

    if api_up:
        print()
        print("== 运行时选择 ==")
        selectors()


def logs():
    if not is_auto_log_enabled():
        print("自动保存日志当前是关闭状态。")
        print("需要实时日志请先执行：sb log on，然后 sb restart。")
        return

    # 优先看 state 记录的当前 run 目录；不可用时按在跑的模式取该模式最新
    cur = load_state().get("current_log_dir") or ""
    run_dir = Path(cur) if cur and Path(cur).exists() else None
    if run_dir is None:
        mode = "tun" if tun_running() else "mixed"
        run_dir = latest_run_dir(mode)
    _show_run_logs(run_dir, "日志")


# ---------------------------------------------------------------------------
# Clash API 命令
# ---------------------------------------------------------------------------
def api():
    proxies = get_proxies()
    print(f"Clash API 可用：{CLASH_API}")
    print(f"proxies 数量：{len(proxies)}")


def ui():
    run(["open", f"{CLASH_API}/ui/"])


def _human_bytes(n):
    """字节数转可读字符串（B/KB/MB/GB/TB）。"""
    n = float(n or 0)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024 or unit == "TB":
            return f"{n:.0f}{unit}" if unit == "B" else f"{n:.1f}{unit}"
        n /= 1024


def conns():
    """抓取 Clash API 活动连接快照：存原始 json，并打印按下行排序的摘要。

    用于网络分析——每条连接的目标域名 / 命中规则 / 出站节点 / 上下行流量。
    """
    try:
        data = clash_request("GET", "/connections")
    except Exception as e:
        raise SbError(
            f"Clash API /connections 请求失败：{CLASH_API}/connections\n错误：{e}\n"
            f"请确认 sing-box 在运行。"
        )

    conn_list = (data or {}).get("connections") or []

    CONNS_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    snap = CONNS_DIR / f"{ts}.json"
    snap.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")

    up = (data or {}).get("uploadTotal", 0)
    down = (data or {}).get("downloadTotal", 0)
    print(f"活动连接：{len(conn_list)}  累计 ↑{_human_bytes(up)} ↓{_human_bytes(down)}")
    print(f"快照已存：{snap}")
    if not conn_list:
        return

    rows = sorted(conn_list, key=lambda c: c.get("download", 0), reverse=True)
    print()
    for c in rows[:40]:
        md = c.get("metadata", {})
        host = md.get("host") or md.get("destinationIP") or "?"
        dport = md.get("destinationPort", "")
        target = f"{host}:{dport}" if dport else host

        rule = c.get("rule", "")
        payload = c.get("rulePayload", "")
        rule_s = f"{rule}:{payload}" if payload else rule
        # 精简超长规则（如 process_name 的进程列表）：保留 "类型 => 动作"，全文见 json
        if len(rule_s) > 48 and "=>" in rule_s:
            head = rule_s.split("=", 1)[0].strip()
            action = rule_s.split("=>", 1)[1].strip()
            rule_s = f"{head} => {action}"

        chains = c.get("chains") or []
        exit_node = chains[0] if chains else "?"  # chains[0] 是真正的出口节点

        cu = _human_bytes(c.get("upload", 0))
        cd = _human_bytes(c.get("download", 0))
        print(f"  ↓{cd:>8} ↑{cu:>8}  {target}  [{rule_s}]  → {exit_node}")

    if len(rows) > 40:
        print(f"  … 其余 {len(rows) - 40} 条见快照文件")


def selectors():
    proxies = get_proxies()
    for name in WANTED_SELECTORS:
        p = proxies.get(name)
        if not p:
            print(f"{name}: API 中未找到")
            continue
        now = p.get("now", "(未知)")
        all_nodes = p.get("all", [])
        print(f"{name}: {now}")
        if all_nodes:
            tail = " ..." if len(all_nodes) > 8 else ""
            print(f"  可选：{', '.join(all_nodes[:8])}{tail}")


# Clash API 里属于「组」的类型
_API_GROUP_TYPES = {"Selector", "URLTest", "Fallback", "LoadBalance"}


def _node_delay(proxies, name):
    """取某节点最近一次测速延迟(ms)：>0 返回数字，0 返回 0(超时)，无记录返回 None。"""
    p = proxies.get(name)
    if not p:
        return None
    hist = p.get("history") or []
    if not hist:
        return None
    return hist[-1].get("delay")


def _resolve_leaf(proxies, name, limit=10):
    """沿 now 一路向下，找到真正的出口叶子节点(非组)。"""
    seen = set()
    cur = name
    while (cur in proxies and proxies[cur].get("type") in _API_GROUP_TYPES
           and cur not in seen and limit > 0):
        seen.add(cur)
        nxt = proxies[cur].get("now")
        if not nxt or nxt == cur:
            break
        cur = nxt
        limit -= 1
    return cur


def groups():
    """显示所有策略组(selector/urltest)的实时情况。"""
    data = load_config()
    proxies = get_proxies()

    group_tags = [o["tag"] for o in data.get("outbounds", [])
                  if o.get("type") in ("selector", "urltest") and "tag" in o]
    defaults = {o["tag"]: o.get("default") for o in data.get("outbounds", [])
                if o.get("type") == "selector"}

    print("== 策略组情况 ==")
    for tag in group_tags:
        p = proxies.get(tag)
        if not p:
            print(f"  {tag}: (运行时未找到，可能需要 sb restart)")
            continue

        ptype = p.get("type", "?")
        now = p.get("now", "?")
        leaf = _resolve_leaf(proxies, now)

        line = f"  [{ptype:8}] {tag} → {now}"
        if leaf != now:
            line += f" → {leaf}"

        delay = _node_delay(proxies, leaf)
        if delay is None:
            line += "  (未测)"
        elif delay == 0:
            line += "  (超时)"
        else:
            line += f"  ({delay}ms)"

        d = defaults.get(tag)
        if d and d != now:
            line += f"   [默认 {d}]"

        print(line)


# ---------------------------------------------------------------------------
# 运行时切换（不重启）
# ---------------------------------------------------------------------------
def _select_in_group(selector, target, missing_hint=None):
    proxies = get_proxies()
    if selector not in proxies:
        raise SbError(f"Clash API 中找不到 selector：{selector}")
    if target not in proxies[selector].get("all", []):
        msg = f"{selector} 里找不到目标：{target}"
        if missing_hint:
            msg += "\n" + missing_hint
        raise SbError(msg)
    clash_select(selector, target)


def list_group_nodes(selector, label=None):
    """打印某策略组的全部候选节点：编号 + ★当前 + 延迟（顶层组顺带显真实出口）。"""
    label = label or selector
    proxies = get_proxies()
    p = proxies.get(selector)
    if not p:
        raise SbError(f"Clash API 中找不到策略组：{selector}（可能需要 sb restart）")
    now = p.get("now")
    all_nodes = p.get("all", [])
    print(f"== {label} 组（{len(all_nodes)} 个；★=当前；编号用于 sb use {label} N）==")
    for i, name in enumerate(all_nodes, 1):
        mark = "★" if name == now else " "
        leaf = _resolve_leaf(proxies, name)
        delay = _node_delay(proxies, leaf)
        d = "未测" if delay is None else ("超时" if delay == 0 else f"{delay}ms")
        line = f" {mark} {i:2}. {name}"
        if leaf != name:
            line += f" → {leaf}"
        print(f"{line}  ({d})")


def _resolve_arg_to_target(selector, arg):
    """把 list/auto/数字/名字 解析成要切换的目标节点名。
    list（含空参）时打印列表并返回 None。"""
    proxies = get_proxies()
    p = proxies.get(selector)
    if not p:
        raise SbError(f"Clash API 中找不到策略组：{selector}（可能需要 sb restart）")
    all_nodes = p.get("all", [])
    s = str(arg).strip()
    low = s.lower()
    if low in ("list", "ls", ""):
        list_group_nodes(selector)
        return None
    if s.isdigit():
        idx = int(s)
        if not (1 <= idx <= len(all_nodes)):
            raise SbError(
                f"{selector} 共 {len(all_nodes)} 个节点，编号需在 1-{len(all_nodes)}；"
                f"先 sb use {selector} list 看看。")
        return all_nodes[idx - 1]
    if low == "auto":
        autos = [n for n in all_nodes if n.endswith("-auto")]
        if not autos:
            raise SbError(f"{selector} 没有自动测速(auto)成员，请用编号或名字选。")
        return autos[0]
    if s in all_nodes:
        return s
    raise SbError(f"{selector} 里找不到：{s}\n用 sb use {selector} list 看可选编号/名字。")


def use_group(selector, arg):
    """统一的运行时切换：list 看节点，数字按编号切，auto/名字也支持。"""
    target = _resolve_arg_to_target(selector, arg)
    if target is None:
        return
    _select_in_group(selector, target)


def use_main_group(arg):
    """对 youtube/google/github/telegram 四组统一操作（成员一致）。"""
    head = SERVICE_SELECTORS[MAIN_SERVICES[0]]
    if str(arg).strip().lower() in ("list", "ls", ""):
        list_group_nodes(head, label="main")
        return
    target = _resolve_arg_to_target(head, arg)
    if target is None:
        return
    for service in MAIN_SERVICES:
        _select_in_group(SERVICE_SELECTORS[service], target)


# ---------------------------------------------------------------------------
# 修改选择器默认值（写入 config；重启后以新默认为准）
# ---------------------------------------------------------------------------
def _set_selector_default(data, selector, target):
    """把 data 里某 selector 的 default 设为 target；返回是否有改动。"""
    for ob in data.get("outbounds", []):
        if ob.get("tag") == selector and ob.get("type") == "selector":
            if target not in ob.get("outbounds", []):
                raise SbError(
                    f"{selector} 的候选里没有 {target}；"
                    f"可选：{', '.join(ob.get('outbounds', []))}"
                )
            if ob.get("default") == target:
                return False
            ob["default"] = target
            return True
    raise SbError(f"配置里找不到选择器：{selector}")


def _config_selector(data, selector):
    """从 config.json 取某 selector 的 outbound 对象。"""
    for ob in data.get("outbounds", []):
        if ob.get("tag") == selector and ob.get("type") == "selector":
            return ob
    raise SbError(f"config.json 里找不到选择器：{selector}")


def _route_list(data, selector, label=None):
    """打印某 selector 的候选成员（编号 + ★当前默认）。基于 config.json，不需 sing-box 在跑。"""
    label = label or selector
    ob = _config_selector(data, selector)
    members = ob.get("outbounds", [])
    default = ob.get("default")
    print(f"== {label} 默认值候选（{len(members)} 个；★=当前默认；编号用于 sb set {label} N）==")
    for i, m in enumerate(members, 1):
        mark = "★" if m == default else " "
        print(f" {mark} {i:2}. {m}")


def _resolve_route_arg(data, selector, arg):
    """list/编号/auto/名字 -> 目标成员名；list（含空参）打印并返回 None。基于 config.json 成员。"""
    ob = _config_selector(data, selector)
    members = ob.get("outbounds", [])
    s = str(arg).strip()
    low = s.lower()
    if low in ("list", "ls", ""):
        _route_list(data, selector)
        return None
    if s.isdigit():
        idx = int(s)
        if not (1 <= idx <= len(members)):
            raise SbError(
                f"{selector} 共 {len(members)} 个候选，编号需在 1-{len(members)}；"
                f"先 sb set {selector} list 看看。")
        return members[idx - 1]
    if low == "auto":
        autos = [m for m in members if m.endswith("-auto")]
        if not autos:
            raise SbError(f"{selector} 没有自动测速(auto)候选，请用编号或名字。")
        return autos[0]
    if s in members:
        return s
    raise SbError(f"{selector} 候选里没有：{s}\n用 sb set {selector} list 看可选编号/名字。")


def route_group(selector, arg):
    """写持久默认值：list 看候选，数字按编号，auto/名字也支持。重启后以此为准。"""
    data = load_config()
    target = _resolve_route_arg(data, selector, arg)
    if target is None:
        return
    if not _set_selector_default(data, selector, target):
        print(f"{selector} 默认值已是 {target}，无需修改。")
        return
    save_config(data)
    check_config()
    print(f"已修改默认值：{selector} -> {target}")
    print(f"重启后以此默认为准；本次运行可即时切换：sb use {selector} {arg}")


def route_main_group(arg):
    """对 youtube/google/github/telegram 四组统一写默认值（成员一致）。"""
    data = load_config()
    head = SERVICE_SELECTORS[MAIN_SERVICES[0]]
    if str(arg).strip().lower() in ("list", "ls", ""):
        _route_list(data, head, label="main")
        return
    target = _resolve_route_arg(data, head, arg)
    if target is None:
        return
    changed = 0
    for service in MAIN_SERVICES:
        if _set_selector_default(data, SERVICE_SELECTORS[service], target):
            changed += 1
    if changed == 0:
        print(f"YouTube / Google / GitHub / Telegram 默认值已都是 {target}，无需修改。")
        return
    save_config(data)
    check_config()
    print(f"已修改默认值：YouTube / Google / GitHub / Telegram -> {target}（{changed} 个）")
    print(f"重启后以此默认为准；本次运行可即时切换：sb use main {arg}")


