def log_on():
    state = load_state()
    state["auto_save_logs"] = True
    save_state(state)
    print("已开启自动保存日志（tun / mixed 统一）。")
    print("下次 sb start / sb restart 后，将按模式自动保存到：")
    print(f"  {DIAG_DIR}/<tun|mixed>/<时间戳>/")
    print("建议现在执行：sb restart")


def log_off():
    state = load_state()
    state["auto_save_logs"] = False
    state["current_log_dir"] = ""
    save_state(state)
    print("已关闭自动保存日志。")
    print("下次 sb start / sb restart 后，后台日志将写入 /dev/null。")
    print("建议现在执行：sb restart")


